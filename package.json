{
  "name": "merkez-crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "electron-dev": "concurrently \"npm run dev\" \"wait-on https://localhost:5173 && electron .\"",
    "dev": "vite --host",
    "build": "node node_modules/vite/bin/vite.js build",
    "dist": "npm run build && electron-builder",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview --host",
    "sync-agent": "node warehouse-sync/sync-agent.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@supabase/supabase-js": "^2.39.0",
    "@types/papaparse": "^5.5.2",
    "antd": "^6.3.5",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "html5-qrcode": "^2.3.8",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.303.0",
    "papaparse": "^5.5.3",
    "pg": "^8.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^14.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.21.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.55.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.2",
    "vite": "^5.0.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.merkez.crm",
    "productName": "Mərkəz CRM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
